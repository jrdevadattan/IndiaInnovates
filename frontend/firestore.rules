rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reports: anyone can read; only authenticated users can create;
    // only the report owner or an admin can update/delete
    match /reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         request.auth.token.admin == true);
    }

    // AI sessions: only the owning user can read/write
    match /ai_sessions/{sessionId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // User profiles: owner can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == userId;
    }
  }
}
