# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/lifeline

# Auth
JWT_ACCESS_SECRET=your_access_secret_minimum_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_chars_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# AI Services
OPENAI_API_KEY=sk-your_openai_api_key
GOOGLE_CLOUD_API_KEY=your_google_cloud_key

# Media Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Maps
GOOGLE_MAPS_API_KEY=your_maps_key

# Firebase (Push Notifications)
# FIREBASE_SERVICE_ACCOUNT_KEY=./src/config/serviceAccountKey.json

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Email (SendGrid)
SENDGRID_API_KEY=SG.your_sendgrid_key
EMAIL_FROM=noreply@lifeline.in

# Payments
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Platform Config
PLATFORM_COMMISSION_RATE=0.10
SLA_CRITICAL_MINUTES=10
SLA_SEVERE_MINUTES=60
SLA_MODERATE_MINUTES=360
